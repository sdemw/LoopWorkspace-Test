# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools
#
# For a list of all available actions, check out
#
#     https://docs.fastlane.tools/actions
#
# For a list of all available plugins, check out
#
#     https://docs.fastlane.tools/plugins/available-plugins
#

default_platform(:ios)

TEAMID = ENV["TEAMID"]
GH_PAT = ENV["GH_PAT"]
GITHUB_WORKSPACE = ENV["GITHUB_WORKSPACE"]
GITHUB_REPOSITORY_OWNER = ENV["GITHUB_REPOSITORY_OWNER"]
FASTLANE_KEY_ID = ENV["FASTLANE_KEY_ID"]
FASTLANE_ISSUER_ID = ENV["FASTLANE_ISSUER_ID"]
FASTLANE_KEY = ENV["FASTLANE_KEY"]
DEVICE_NAME = ENV["DEVICE_NAME"]
DEVICE_ID = ENV["DEVICE_ID"]

ENV["FASTLANE_XCODEBUILD_SETTINGS_TIMEOUT"] = "120"

platform :ios do
  desc "Build Loop"
  lane :build_loop do
    setup_ci if ENV["CI"]

    # Allow CI build lane to repair/create profiles if needed
    ENV["MATCH_READONLY"] = false.to_s

    update_project_team(
      path: "#{GITHUB_WORKSPACE}/Loop/Loop.xcodeproj",
      teamid: "#{TEAMID}"
    )

    api_key = app_store_connect_api_key(
      key_id: "#{FASTLANE_KEY_ID}",
      issuer_id: "#{FASTLANE_ISSUER_ID}",
      key_content: "#{FASTLANE_KEY}"
    )

    previous_build_number = latest_testflight_build_number(
      app_identifier: "com.#{TEAMID}.loopinsights.Loop",
      api_key: api_key,
      initial_build_number: 1
    )

    current_build_number = previous_build_number + 1

    increment_build_number(
      xcodeproj: "#{GITHUB_WORKSPACE}/Loop/Loop.xcodeproj",
      build_number: current_build_number
    )

    match(
      type: "appstore",
      readonly: false,
      force: true,
      git_basic_authorization: Base64.strict_encode64("#{GITHUB_REPOSITORY_OWNER}:#{GH_PAT}"),
      app_identifier: [
        "com.#{TEAMID}.loopinsights.Loop",
        "com.#{TEAMID}.loopinsights.Loop.statuswidget",
        "com.#{TEAMID}.loopinsights.Loop.LoopWatch.watchkitextension",
        "com.#{TEAMID}.loopinsights.Loop.LoopWatch",
        "com.#{TEAMID}.loopinsights.Loop.Loop-Intent-Extension",
        "com.#{TEAMID}.loopinsights.Loop.LoopWidgetExtension"
      ]
    )

    mapping = Actions.lane_context[
      SharedValues::MATCH_PROVISIONING_PROFILE_MAPPING
    ]

    update_code_signing_settings(
      path: "#{GITHUB_WORKSPACE}/Loop/Loop.xcodeproj",
      profile_name: mapping["com.#{TEAMID}.loopinsights.Loop"],
      code_sign_identity: "iPhone Distribution",
      targets: ["Loop"]
    )

    update_code_signing_settings(
      path: "#{GITHUB_WORKSPACE}/Loop/Loop.xcodeproj",
      code_sign_identity: "iPhone Distribution",
      targets: ["LoopCore", "LoopCore-watchOS", "LoopUI"]
    )

    update_code_signing_settings(
      path: "#{GITHUB_WORKSPACE}/Loop/Loop.xcodeproj",
      profile_name: mapping["com.#{TEAMID}.loopinsights.Loop.statuswidget"],
      code_sign_identity: "iPhone Distribution",
      targets: ["Loop Status Extension"]
    )

    update_code_signing_settings(
      path: "#{GITHUB_WORKSPACE}/Loop/Loop.xcodeproj",
      profile_name: mapping["com.#{TEAMID}.loopinsights.Loop.LoopWatch.watchkitextension"],
      code_sign_identity: "iPhone Distribution",
      targets: ["WatchApp Extension"]
    )

    update_code_signing_settings(
      path: "#{GITHUB_WORKSPACE}/Loop/Loop.xcodeproj",
      profile_name: mapping["com.#{TEAMID}.loopinsights.Loop.LoopWatch"],
      code_sign_identity: "iPhone Distribution",
      targets: ["WatchApp"]
    )

    update_code_signing_settings(
      path: "#{GITHUB_WORKSPACE}/Loop/Loop.xcodeproj",
      profile_name: mapping["com.#{TEAMID}.loopinsights.Loop.Loop-Intent-Extension"],
      code_sign_identity: "iPhone Distribution",
      targets: ["Loop Intent Extension"]
    )

    update_code_signing_settings(
      path: "#{GITHUB_WORKSPACE}/Loop/Loop.xcodeproj",
      profile_name: mapping["com.#{TEAMID}.loopinsights.Loop.LoopWidgetExtension"],
      code_sign_identity: "iPhone Distribution",
      targets: ["Loop Widget Extension"]
    )

    gym(
      export_method: "app-store",
      scheme: "LoopWorkspace",
      output_name: "Loop.ipa",
      configuration: "Release",
      destination: "generic/platform=iOS",
      buildlog_path: "buildlog"
    )

    copy_artifacts(
      target_path: "artifacts",
      artifacts: ["*.mobileprovision", "*.ipa", "*.dSYM.zip"]
    )
  end

  desc "Push to TestFlight"
  lane :release do
    api_key = app_store_connect_api_key(
      key_id: "#{FASTLANE_KEY_ID}",
      issuer_id: "#{FASTLANE_ISSUER_ID}",
      key_content: "#{FASTLANE_KEY}"
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: "Loop.ipa",
      skip_submission: false,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Provision Identifiers and Certificates"
  lane :identifiers do
    setup_ci if ENV["CI"]
    ENV["MATCH_READONLY"] = false.to_s

    app_store_connect_api_key(
      key_id: "#{FASTLANE_KEY_ID}",
      issuer_id: "#{FASTLANE_ISSUER_ID}",
      key_content: "#{FASTLANE_KEY}"
    )

    def configure_bundle_id(name, identifier, capabilities)
      bundle_id = Spaceship::ConnectAPI::BundleId.find(identifier) || Spaceship::ConnectAPI::BundleId.create(
        name: name,
        identifier: identifier,
        platform: "IOS"
      )
      existing = bundle_id.get_capabilities.map(&:capability_type)
      capabilities.reject { |c| existing.include?(c) }.each do |cap|
        bundle_id.create_capability(cap)
      end
    end

    configure_bundle_id("Loop", "com.#{TEAMID}.loopinsights.Loop", [
      Spaceship::ConnectAPI::BundleIdCapability::Type::APP_GROUPS,
      Spaceship::ConnectAPI::BundleIdCapability::Type::HEALTHKIT,
      Spaceship::ConnectAPI::BundleIdCapability::Type::PUSH_NOTIFICATIONS,
      Spaceship::ConnectAPI::BundleIdCapability::Type::SIRIKIT,
      Spaceship::ConnectAPI::BundleIdCapability::Type::NFC_TAG_READING
    ])

    configure_bundle_id("Loop Intent Extension", "com.#{TEAMID}.loopinsights.Loop.Loop-Intent-Extension", [
      Spaceship::ConnectAPI::BundleIdCapability::Type::APP_GROUPS
    ])

    configure_bundle_id("Loop Status Extension", "com.#{TEAMID}.loopinsights.Loop.statuswidget", [
      Spaceship::ConnectAPI::BundleIdCapability::Type::APP_GROUPS
    ])

    configure_bundle_id("WatchApp", "com.#{TEAMID}.loopinsights.Loop.LoopWatch", [])

    configure_bundle_id("WatchApp Extension", "com.#{TEAMID}.loopinsights.Loop.LoopWatch.watchkitextension", [
      Spaceship::ConnectAPI::BundleIdCapability::Type::HEALTHKIT,
      Spaceship::ConnectAPI::BundleIdCapability::Type::SIRIKIT
    ])

    configure_bundle_id("Loop Widget Extension", "com.#{TEAMID}.loopinsights.Loop.LoopWidgetExtension", [
      Spaceship::ConnectAPI::BundleIdCapability::Type::APP_GROUPS
    ])

    # Create the app group in the Developer Portal and associate it with the
    # bundle IDs that declare APP_GROUPS.
    app_group_identifier = "group.com.#{TEAMID}.loopinsights.LoopGroup"
    app_group_ids_to_associate = [
      "com.#{TEAMID}.loopinsights.Loop",
      "com.#{TEAMID}.loopinsights.Loop.statuswidget",
      "com.#{TEAMID}.loopinsights.Loop.Loop-Intent-Extension",
      "com.#{TEAMID}.loopinsights.Loop.LoopWidgetExtension"
    ]

    # Helper: obtain a JWT string from spaceship's stored token or env credentials.
    def asc_jwt_token
      token_obj = Spaceship::ConnectAPI.token
      if token_obj
        begin; return token_obj.text; rescue NoMethodError; end
        begin; return token_obj.generate_token; rescue NoMethodError; end
      end
      # Fallback: generate JWT directly from environment credentials
      require 'openssl'
      require 'jwt'
      key_id      = ENV["FASTLANE_KEY_ID"]
      issuer_id   = ENV["FASTLANE_ISSUER_ID"]
      key_content = ENV["FASTLANE_KEY"]
      raise "Missing API credentials for JWT generation" unless key_id && issuer_id && key_content
      private_key = OpenSSL::PKey::EC.new(key_content)
      payload = { iss: issuer_id, iat: Time.now.to_i, exp: Time.now.to_i + 1200, aud: "appstoreconnect-v1" }
      JWT.encode(payload, private_key, "ES256", { kid: key_id })
    end

    # Helper: make an authenticated App Store Connect REST API request.
    # Returns [http_status_code (Integer), parsed_response_body (Hash)].
    def asc_api_request(method, path, body = nil)
      require 'net/http'
      require 'uri'
      require 'json'
      uri  = URI("https://api.appstoreconnect.apple.com/v1/#{path}")
      http = Net::HTTP.new(uri.host, uri.port)
      http.use_ssl     = true
      http.read_timeout = 30
      req = (method == :post ? Net::HTTP::Post : Net::HTTP::Get).new(uri)
      req["Authorization"] = "Bearer #{asc_jwt_token}"
      req["Content-Type"]  = "application/json"
      req.body = body.to_json if body
      resp = http.request(req)
      parsed = begin; JSON.parse(resp.body); rescue; {}; end
      [resp.code.to_i, parsed]
    end

    app_group_id = nil

    # --- Step 1a: look for the app group via existing bundle ID associations ---
    # Uses the HTTP API directly (bundleIds/{id}/appGroups) to avoid spaceship
    # version quirks with get_app_groups returning empty results.
    UI.message("Checking existing bundle ID associations for app group '#{app_group_identifier}'...")
    app_group_ids_to_associate.each do |bid|
      break if app_group_id
      begin
        bundle = Spaceship::ConnectAPI::BundleId.find(bid)
        next unless bundle
        status, resp = asc_api_request(:get, "bundleIds/#{bundle.id}/appGroups")
        UI.message("GET bundleIds/#{bundle.id}/appGroups → HTTP #{status}, count: #{(resp['data'] || []).size}")
        data = resp["data"] || []
        matching = data.find do |g|
          (g.dig("attributes", "identifier") || g.dig("attributes", "groupIdentifier")) == app_group_identifier
        end
        if matching
          app_group_id = matching["id"]
          UI.message("Found app group '#{app_group_identifier}' on #{bid}: id=#{app_group_id}")
        end
      rescue => e
        UI.important("Could not check existing app groups on #{bid}: #{e.message}")
      end
    end

    # --- Step 1b: find or create via API if not found above ---
    unless app_group_id
      begin
        # Try the typed AppGroup model (available in newer spaceship versions)
        all_groups = Spaceship::ConnectAPI::AppGroup.all
        existing = all_groups.find { |g| g.identifier == app_group_identifier }
        if existing
          app_group_id = existing.id
          UI.message("Found existing app group #{app_group_identifier} (#{app_group_id})")
        else
          new_group = Spaceship::ConnectAPI::AppGroup.create(
            name: "LoopInsights Group",
            identifier: app_group_identifier
          )
          app_group_id = new_group.id
          UI.success("Created app group #{app_group_identifier} (#{app_group_id})")
        end
      rescue NameError
        # AppGroup class not present in this fastlane/spaceship version — use direct HTTP
        UI.important("Spaceship::ConnectAPI::AppGroup not available; using HTTP API...")
        begin
          require 'uri'
          # Use raw brackets in the filter (not percent-encoded) — some API versions require this
          encoded_id = URI.encode_www_form_component(app_group_identifier)
          status, resp = asc_api_request(:get, "appGroups?filter[groupIdentifier]=#{encoded_id}")
          UI.important("GET appGroups → HTTP #{status}, data count: #{(resp['data'] || []).size}")
          data = resp["data"] || []
          if data.any?
            app_group_id = data.first["id"]
            UI.message("Found existing app group via HTTP: #{app_group_identifier} (#{app_group_id})")
          else
            UI.important("App group not found via GET — attempting POST to create...")
            status, resp = asc_api_request(:post, "appGroups", {
              "data" => {
                "type" => "appGroups",
                "attributes" => {
                  "name"            => "LoopInsights Group",
                  "groupIdentifier" => app_group_identifier
                }
              }
            })
            UI.important("POST appGroups → HTTP #{status}: #{resp.to_json}")
            if status < 300 && resp["data"]
              app_group_id = resp["data"]["id"]
              UI.success("Created app group via HTTP: #{app_group_identifier} (#{app_group_id})")
            elsif status == 403
              UI.error("HTTP 403: API key lacks Admin permission to create app groups.")
              UI.error("Please create '#{app_group_identifier}' manually in the Apple Developer Portal.")
            elsif (resp["errors"] || []).any? { |e| (e["code"] || "").include?("DUPLICATE") }
              # Group already exists — re-fetch it
              UI.important("App group already exists (DUPLICATE); re-fetching...")
              _, resp2 = asc_api_request(:get, "appGroups?filter[groupIdentifier]=#{encoded_id}")
              UI.important("Re-fetch HTTP #{_}: #{resp2.to_json}")
              app_group_id = ((resp2["data"] || []).first || {})["id"]
              UI.message("App group re-fetched: #{app_group_identifier} (#{app_group_id})")
            else
              UI.important("Failed to create app group: HTTP #{status} — #{resp.to_json}")
            end
          end
        rescue => http_err
          UI.important("HTTP API failed: #{http_err.message}")
          UI.important(http_err.backtrace.first(3).join("\n"))
        end
      rescue => err
        UI.important("AppGroup setup failed: #{err.message}")
      end
    end

    # --- Step 2: associate the app group with relevant bundle IDs ---
    if app_group_id
      app_group_ids_to_associate.each do |bid|
        bundle = Spaceship::ConnectAPI::BundleId.find(bid)
        unless bundle
          UI.important("Bundle ID #{bid} not found in portal, skipping app group association")
          next
        end

        already_associated = false
        begin
          _, assoc_resp = asc_api_request(:get, "bundleIds/#{bundle.id}/appGroups")
          already_associated = (assoc_resp["data"] || []).any? do |g|
            (g.dig("attributes", "identifier") || g.dig("attributes", "groupIdentifier")) == app_group_identifier
          end
        rescue => e
          UI.important("Could not check app groups for #{bid}: #{e.message}")
        end

        if already_associated
          UI.message("#{bid} already has app group #{app_group_identifier}")
          next
        end

        associated = false
        begin
          bundle.associate_app_groups([app_group_id])
          UI.success("Associated #{app_group_identifier} with #{bid}")
          associated = true
        rescue NoMethodError
          # Method unavailable in this spaceship version — fall through to HTTP
        rescue => e
          UI.important("Spaceship associate_app_groups failed for #{bid}: #{e.message}")
        end

        unless associated
          status, resp = asc_api_request(
            :post,
            "bundleIds/#{bundle.id}/relationships/appGroups",
            { "data" => [{ "type" => "appGroups", "id" => app_group_id }] }
          )
          # 409 = conflict (already associated) — treat as success
          if status < 300 || status == 409
            UI.success("Associated #{app_group_identifier} with #{bid} via HTTP")
            associated = true
          else
            raise "Failed to associate '#{app_group_identifier}' with '#{bid}': HTTP #{status} — #{resp.to_json}"
          end
        end
      end
    else
      UI.error("")
      UI.error("❌ Could not create or find app group '#{app_group_identifier}'.")
      UI.error("   Please manually create this App Group in the Apple Developer Portal:")
      UI.error("   1. Go to Certificates, Identifiers & Profiles → Identifiers → App Groups")
      UI.error("   2. Create a new App Group with identifier: #{app_group_identifier}")
      UI.error("   3. Edit each of these bundle IDs and associate the app group:")
      app_group_ids_to_associate.each { |bid| UI.error("      - #{bid}") }
      UI.error("   Then re-run the '2. Add Identifiers' workflow.")
      UI.error("")
      raise "App group '#{app_group_identifier}' could not be created or found. Manual intervention required — see instructions above."
    end

  end

  desc "Provision Certificates"
  lane :certs do
    setup_ci if ENV["CI"]
    ENV["MATCH_READONLY"] = false.to_s

    app_store_connect_api_key(
      key_id: "#{FASTLANE_KEY_ID}",
      issuer_id: "#{FASTLANE_ISSUER_ID}",
      key_content: "#{FASTLANE_KEY}"
    )

    match(
      type: "appstore",
      force: false,
      verbose: true,
      git_basic_authorization: Base64.strict_encode64("#{GITHUB_REPOSITORY_OWNER}:#{GH_PAT}"),
      app_identifier: [
        "com.#{TEAMID}.loopinsights.Loop",
        "com.#{TEAMID}.loopinsights.Loop.statuswidget",
        "com.#{TEAMID}.loopinsights.Loop.LoopWatch.watchkitextension",
        "com.#{TEAMID}.loopinsights.Loop.LoopWatch",
        "com.#{TEAMID}.loopinsights.Loop.Loop-Intent-Extension",
        "com.#{TEAMID}.loopinsights.Loop.LoopWidgetExtension"
      ]
    )
  end

  desc "Validate Secrets"
  lane :validate_secrets do
    setup_ci if ENV["CI"]
    ENV["MATCH_READONLY"] = true.to_s

    app_store_connect_api_key(
      key_id: "#{FASTLANE_KEY_ID}",
      issuer_id: "#{FASTLANE_ISSUER_ID}",
      key_content: "#{FASTLANE_KEY}"
    )

    def find_bundle_id(identifier)
      bundle_id = Spaceship::ConnectAPI::BundleId.find(identifier)
    end

    find_bundle_id("com.#{TEAMID}.loopinsights.Loop")

    match(
      type: "appstore",
      git_basic_authorization: Base64.strict_encode64("#{GITHUB_REPOSITORY_OWNER}:#{GH_PAT}"),
      app_identifier: []
    )
  end

  desc "Nuke Certs"
  lane :nuke_certs do
    setup_ci if ENV["CI"]
    ENV["MATCH_READONLY"] = false.to_s

    app_store_connect_api_key(
      key_id: "#{FASTLANE_KEY_ID}",
      issuer_id: "#{FASTLANE_ISSUER_ID}",
      key_content: "#{FASTLANE_KEY}"
    )

    match_nuke(
      type: "appstore",
      team_id: "#{TEAMID}",
      skip_confirmation: true,
      git_basic_authorization: Base64.strict_encode64("#{GITHUB_REPOSITORY_OWNER}:#{GH_PAT}")
    )
  end

  desc "Check Certificates and Trigger Workflow for Expired or Missing Certificates"
  lane :check_and_renew_certificates do
    setup_ci if ENV["CI"]
    ENV["MATCH_READONLY"] = false.to_s

    api_key = app_store_connect_api_key(
      key_id: ENV["FASTLANE_KEY_ID"],
      issuer_id: ENV["FASTLANE_ISSUER_ID"],
      key_content: ENV["FASTLANE_KEY"]
    )

    new_certificate_needed = false

    certificates = Spaceship::ConnectAPI::Certificate.all
    distribution_certs = certificates.select { |cert| cert.certificate_type == "DISTRIBUTION" }

    if distribution_certs.empty?
      puts "No Distribution certificates found! Triggering action to create certificate."
      new_certificate_needed = true
    else
      distribution_certs.each do |cert|
        expiration_date = Time.parse(cert.expiration_date)

        puts "Current Distribution Certificate: #{cert.id}, Expiration date: #{expiration_date}"

        if expiration_date < Time.now
          puts "Distribution Certificate #{cert.id} is expired! Triggering action to renew certificate."
          new_certificate_needed = true
        else
          puts "Distribution certificate #{cert.id} is valid. No action required."
        end
      end
    end

    file_path = File.expand_path("new_certificate_needed.txt")
    File.write(file_path, new_certificate_needed ? "true" : "false")

    puts ""
    puts "Absolute path of new_certificate_needed.txt: #{file_path}"
    new_certificate_needed_content = File.read(file_path)
    puts "Certificate creation or renewal needed: #{new_certificate_needed_content}"
  end
end
